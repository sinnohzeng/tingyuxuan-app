{
  "mcpServers": {
    "minimax": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "minimax-mcp-js"],
      "env": {
        "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
        "MINIMAX_MCP_BASE_PATH": "${MINIMAX_MCP_BASE_PATH:-./}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com",
        "MINIMAX_RESOURCE_MODE": "local"
      }
    }
  }
}
